#!/bin/bash
#
# QMK Field Kit Flash Wrapper
# Python-based replacement for the original flash.sh.
#
# Resolves a Python interpreter that has the `hid` library available so an
# unrelated virtualenv on PATH (e.g. another project's venv without hidapi
# installed) doesn't silently break HID-dependent features like side-lock
# detection.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ------------------------------------------------------------------
# Pick the first interpreter from the candidate list that can import hid.
# Order: explicit override -> active venv -> PATH python3 -> system pythons.
# ------------------------------------------------------------------
can_import_hid() {
    local py="$1"
    case "$py" in
        /*) [ -x "$py" ] || return 1 ;;
        *)  command -v "$py" >/dev/null 2>&1 || return 1 ;;
    esac
    "$py" -c 'import hid' 2>/dev/null
}

PY_WITH_HID=""
for candidate in \
    "${QMK_FIELD_KIT_PYTHON:-}" \
    "${VIRTUAL_ENV:+$VIRTUAL_ENV/bin/python3}" \
    python3 \
    /usr/bin/python3 \
    /usr/bin/python
do
    [ -n "$candidate" ] || continue
    if can_import_hid "$candidate"; then
        PY_WITH_HID="$candidate"
        break
    fi
done

if [ -z "$PY_WITH_HID" ]; then
    echo "❌ No Python interpreter with the 'hid' library was found." >&2
    echo "   The field kit needs hidapi for HID features (e.g. side-lock)." >&2
    echo "   Fix one of:" >&2
    echo "     - pip install hidapi   (in your current environment)" >&2
    echo "     - export QMK_FIELD_KIT_PYTHON=/path/to/python   (a python with hidapi)" >&2
    exit 1
fi

# Extract keyboard and keymap from QMK config (tolerate qmk-config failures;
# the empty checks below handle missing config with a clear message).
KEYBOARD=$(qmk config user.keyboard 2>/dev/null | cut -d'=' -f2 || true)
KEYMAP=$(qmk config user.keymap 2>/dev/null | cut -d'=' -f2 || true)

if [ -z "$KEYBOARD" ] || [ -z "$KEYMAP" ]; then
    echo "Error: Could not extract keyboard or keymap from QMK config" >&2
    echo "Please ensure QMK is properly configured with" >&2
    echo "  'qmk config user.keyboard=<keyboard>' and 'qmk config user.keymap=<keymap>'" >&2
    exit 1
fi

# Navigate to the QMK Field Kit directory
FIELD_KIT_DIR="$SCRIPT_DIR/keyboards/$KEYBOARD/qmk-field-kit"

if [ ! -d "$FIELD_KIT_DIR" ]; then
    echo "Error: QMK Field Kit not found at $FIELD_KIT_DIR" >&2
    echo "Please ensure the qmk-field-kit directory exists and contains the Python modules." >&2
    exit 1
fi

cd "$FIELD_KIT_DIR"

# Run the Python module with all arguments passed through
exec "$PY_WITH_HID" -m qmk_field_kit "$@"
